<UserControl x:Class="MuchaCurve.LumaVsSatEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="250" MinHeight="280">
    <UserControl.Resources>
        <SolidColorBrush x:Key="CanvasBgBrush" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="GridBrush" Color="#FF333333"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFCCCCCC"/>
        <SolidColorBrush x:Key="TabBorderBrush" Color="#FF666666"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー: スポイト・リセットボタン -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
            <Button x:Name="BtnEyedropper"
                    Height="22" Width="26"
                    Padding="4,2" Margin="0,0,4,0"
                    Background="Transparent"
                    BorderBrush="{StaticResource TabBorderBrush}"
                    BorderThickness="1"
                    ToolTip="画面の色を取得して彩度ポイントを追加"
                    Cursor="Hand"
                    Click="OnEyedropperClicked">
                  <Image Width="14" Height="14" Stretch="Uniform"
                      Source="pack://siteoforigin:,,,/color.svg"
                      RenderOptions.BitmapScalingMode="HighQuality"/>
            </Button>
            <Button x:Name="BtnReset" Content="リセット" 
                    FontSize="11" Height="22"
                    Padding="6,0" Margin="0,0,0,0"
                    Foreground="{StaticResource TextBrush}"
                    Background="Transparent"
                    BorderBrush="{StaticResource TabBorderBrush}"
                    BorderThickness="1"
                    ToolTip="彩度倍率をリセット"
                    Cursor="Hand"
                    Click="OnResetClicked"/>
        </StackPanel>

            <!-- 適用率ラベルの下にエフェクト効果トグル -->
            <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,28,0,0">
                <TextBlock Text="エフェクト効果" FontSize="11" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                <CheckBox x:Name="ChkEnabled" Content="有効" IsChecked="True" FontSize="11" Foreground="{StaticResource TextBrush}"/>
            </StackPanel>

        <!-- カーブ描画領域 -->
        <Border Grid.Row="1" Background="{StaticResource CanvasBgBrush}" 
                BorderBrush="{StaticResource GridBrush}" BorderThickness="1"
                ClipToBounds="True">
            <Canvas x:Name="CurveCanvas"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                    MouseMove="Canvas_MouseMove"
                    MouseRightButtonDown="Canvas_MouseRightButtonDown"
                    LostMouseCapture="Canvas_LostMouseCapture"
                    SizeChanged="Canvas_SizeChanged"
                    Background="Transparent"/>
        </Border>

        <!-- 輝度ラベル (0% ~ 100%) -->
        <Grid Grid.Row="2" Margin="0,2,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="0%" FontSize="10" 
                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Left"/>
            <TextBlock Grid.Column="1" Text="25%" FontSize="10" 
                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="50%" FontSize="10" 
                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="3" Text="75%" FontSize="10" 
                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="100%" FontSize="10" 
                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</UserControl>
