<UserControl x:Class="MuchaCurve.CurveEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="250" MinHeight="280">
    <UserControl.Resources>
        <SolidColorBrush x:Key="CanvasBgBrush" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="GridBrush" Color="#FF333333"/>
        <SolidColorBrush x:Key="DiagonalBrush" Color="#FF505050"/>
        <SolidColorBrush x:Key="MasterBrush" Color="#FFCCCCCC"/>
        <SolidColorBrush x:Key="RedBrush" Color="#FFE06060"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#FF70C070"/>
        <SolidColorBrush x:Key="BlueBrush" Color="#FF6090E0"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFCCCCCC"/>

        <SolidColorBrush x:Key="TabBorderBrush" Color="#FF666666"/>
        <SolidColorBrush x:Key="TabActiveBorderBrush" Color="#FFAAAAAA"/>
        <SolidColorBrush x:Key="TabHoverBrush" Color="#30338DCC"/>
        <SolidColorBrush x:Key="TabCheckedBrush" Color="#FF3A3A3C"/>

        <!-- チャンネル切替タブのスタイル (YMM4風: 枠線ボックス) -->
        <Style x:Key="ChannelTabStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" 
                                Background="Transparent"
                                BorderBrush="{StaticResource TabBorderBrush}"
                                BorderThickness="1" Padding="8,2" Margin="0,0,2,0"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" 
                                        Value="{StaticResource TabCheckedBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" 
                                        Value="{StaticResource TabActiveBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" 
                                        Value="{StaticResource TabHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="MinWidth" Value="28"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

            <!-- チャンネル切替タブ -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                <RadioButton x:Name="TabMaster" Content="Y" 
                             GroupName="Channel" IsChecked="True"
                             Foreground="{StaticResource MasterBrush}"
                             Style="{StaticResource ChannelTabStyle}"
                             Checked="OnChannelChanged"/>
                <RadioButton x:Name="TabRed" Content="R" 
                             GroupName="Channel"
                             Foreground="{StaticResource RedBrush}"
                             Style="{StaticResource ChannelTabStyle}"
                             Checked="OnChannelChanged"/>
                <RadioButton x:Name="TabGreen" Content="G" 
                             GroupName="Channel"
                             Foreground="{StaticResource GreenBrush}"
                             Style="{StaticResource ChannelTabStyle}"
                             Checked="OnChannelChanged"/>
                <RadioButton x:Name="TabBlue" Content="B" 
                             GroupName="Channel"
                             Foreground="{StaticResource BlueBrush}"
                             Style="{StaticResource ChannelTabStyle}"
                             Checked="OnChannelChanged"/>

                <!-- リセットボタン -->
                <Button x:Name="BtnReset" Content="リセット" 
                        FontSize="11" Height="22"
                        Padding="6,0" Margin="8,0,0,0"
                        Foreground="{StaticResource TextBrush}"
                        Background="Transparent"
                        BorderBrush="{StaticResource TabBorderBrush}"
                        BorderThickness="1"
                        ToolTip="現在のチャンネルをリセット"
                        Cursor="Hand"
                        Click="OnResetClicked"/>
            </StackPanel>

                <!-- 適用率ラベルの下にエフェクト効果トグル -->
                <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,28,0,0">
                    <TextBlock Text="エフェクト効果" FontSize="11" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"/>
                    <CheckBox x:Name="ChkEnabled" Content="有効" IsChecked="True" FontSize="11" Foreground="{StaticResource TextBrush}"/>
                </StackPanel>

            <!-- カーブ描画領域 -->
            <Border Grid.Row="1" Background="{StaticResource CanvasBgBrush}" 
                    BorderBrush="{StaticResource GridBrush}" BorderThickness="1"
                    ClipToBounds="True">
                <Canvas x:Name="CurveCanvas"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                        MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                        MouseMove="Canvas_MouseMove"
                        SizeChanged="Canvas_SizeChanged"
                        Background="Transparent"/>
            </Border>
    </Grid>
</UserControl>
